# ============================================
# 减脂营营养师AI智能工作台 - 环境变量配置
# ============================================

# ----- 必填：数据库 (Supabase PostgreSQL) -----
# 在 https://supabase.com 创建项目后，获取连接字符串
# Settings -> Database -> Connection string -> URI
DATABASE_URL="postgresql://postgres:[YOUR-PASSWORD]@db.[YOUR-PROJECT-ID].supabase.co:5432/postgres"

# ----- 必填：JWT 密钥 -----
# 生成方式: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET="change-this-to-a-random-secret-string-in-production"

# ----- 必填：Deepseek API Key -----
# 获取: https://platform.deepseek.com/api_keys
DEEPSEEK_API_KEY=""

# ----- 可选：FastGPT 智能体 API -----
# 接入饮食方案、饮食识别、配料分析、菜单建议四个功能
# FASTGPT_API_URL="https://your-fastgpt-instance.com/api/v1"

# ----- 可选配置 -----
PORT=3000
JWT_EXPIRES_IN=7d
FRONTEND_URL=http://localhost:5173
NODE_ENV=development
